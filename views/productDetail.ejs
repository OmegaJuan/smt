<%- include("partials/header") %>

    <section class="product-detail-container">

        <div class="product-detail">

            <!-- LEFT: PRODUCT IMAGE -->
            <div class="product-gallery">

                <% var images=[]; if (product.images && product.images.length> 0) {
                    images = product.images;
                    } else if (product.image) {
                    images = [product.image];
                    }
                    %>

                    <div class="thumbnail-container">
                        <% for (var i=0; i < images.length; i++) { %>
                            <img src="<%= images[i] %>" class="thumbnail <%= i === 0 ? 'active' : '' %>"
                                onclick="changeImage('<%= images[i] %>', this)">
                            <% } %>
                    </div>

                    <div class="main-image-container">
                        <% if (images.length> 0) { %>
                            <img id="mainImage" src="<%= images[0] %>" alt="<%= product.name %>">
                            <% } %>
                    </div>

            </div>

            <!-- RIGHT: PRODUCT INFO -->
            <div class="product-detail-info">

                <h1 class="product-title">
                    <%= product.name %>
                </h1>
                <p class="product-price">$<%= product.price %>
                </p>

                <form action="/cart/add/<%= product.id %>" method="POST" class="cart-form"
                    onsubmit="return validateSelection()">

                    <!-- SIZE (เฉพาะสินค้าที่มี sizes) -->
                    <% if (product.sizes?.length) { %>
                        <div class="product-option">
                            <label for="size">Size</label>
                            <select id="size" name="size">
                                <option value="">Select Size</option>
                                <% product.sizes.forEach(size=> { %>
                                    <option value="<%= size %>">
                                        <%= size %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>
                        <% } %>

                            <!-- QUANTITY -->
                            <div class="product-option">
                                <label for="qty">Quantity</label>
                                <input type="number" name="quantity" id="qty" value="1" min="1">
                            </div>

                            <button type="submit" class="add-to-cart-btn">
                                Add to Cart
                            </button>

                </form>

                <!-- WISHLIST BUTTON -->
                <form action="/wishlist/add" method="POST" class="wishlist-form">
                    <input type="hidden" name="productId" value="<%= product.id %>">
                    <input type="hidden" name="size" id="wishlist-size">

                    <button type="submit" class="wishlist-btn">
                        ♡ Add to Wishlist
                    </button>
                </form>

                <!-- DESCRIPTION -->
                <div class="product-description">
                    <h3>Description</h3>
                    <p>
                        <%= product.description || "No description available." %>
                    </p>
                </div>

            </div>

        </div>

    </section>

    <!-- Store product data for client scripts -->
    <div id="product-data" data-has-sizes="<%= product.sizes && product.sizes.length > 0 %>" style="display:none;">
    </div>

    <script>
        function validateSelection() {
            const productData = document.getElementById("product-data");
            const hasSizes = productData ? (productData.dataset.hasSizes === 'true') : false;

            if (hasSizes) {
                const size = document.getElementById("size").value;
                if (!size) {
                    alert("Please select a size first.");
                    return false;
                }
            }
            return true;
        }

        function changeImage(src, el) {
            document.getElementById("mainImage").src = src;

            document.querySelectorAll(".thumbnail").forEach(img => {
                img.classList.remove("active");
            });

            el.classList.add("active");
        }
    </script>
    <script>
        const sizeSelect = document.getElementById("size");
        const wishlistSize = document.getElementById("wishlist-size");

        if (sizeSelect && wishlistSize) {
            sizeSelect.addEventListener("change", () => {
                wishlistSize.value = sizeSelect.value;
            });
        }
    </script>

    <%- include("partials/footer") %>
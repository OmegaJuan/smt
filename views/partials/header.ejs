            </div>
          </div>
        </div>
      </div>


      <!-- ACCESSORIES -->
      <div class="nav-item">
        Accessories
        <div class="dropdown">
          <div class="drop-links">
            <h4>Men</h4>
            <a href="/products/shop?brand=Gucci&category=Accessories&department=men">Gucci</a>
            <a href="/products/shop?brand=Dior&category=Accessories&department=men">Dior</a>
            <a href="/products/shop?brand=Seiko&category=Accessories&department=men">Seiko</a>
            <a href="/products/shop?brand=Louis+Vuitton&category=Accessories&department=men">Louis Vuitton</a>
            <a href="/products/shop?brand=Hermès&category=Accessories&department=men">Hermès</a>
          </div>

          <div class="drop-links">
            <h4>Women</h4>
            <a href="/products/shop?brand=Gucci&category=Accessories&department=women">Gucci</a>
            <a href="/products/shop?brand=Dior&category=Accessories&department=women">Dior</a>
            <a href="/products/shop?brand=Seiko&category=Accessories&department=women">Seiko</a>
            <a href="/products/shop?brand=Louis+Vuitton&category=Accessories&department=women">Louis Vuitton</a>

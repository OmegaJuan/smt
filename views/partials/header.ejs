          <div class="drop-images">
            <div>
              <img src="https://m.media-amazon.com/images/I/71F96Kn8k9L._AC_UY1000_.jpg">
            </div>
            <div>
              <img src="https://www.pickett.co.uk/cdn/shop/files/short-wallet-wallets-928172_1000x.jpg?v=1757701061">

          <div class="drop-links">
            <h4>Footwear</h4>
            <a href="/products/shop?category=Shoes">All Sneaker & Shoes</a>
          </div>

          <div class="drop-links">
            <h4>Brands</h4>
            <a href="/products/shop?brand=Adidas&category=Shoes">Adidas</a>
            <a href="/products/shop?brand=Nike&category=Shoes">Nike</a>
            <a href="/products/shop?brand=Balenciaga&category=Shoes">Balenciaga</a>
            <a href="/products/shop?brand=A+Bathing+Ape&category=Shoes">A Bathing Ape</a>
